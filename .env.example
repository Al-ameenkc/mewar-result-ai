# Supabase (required)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Supabase service role — server-only, never expose to the browser
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# OpenAI (optional — heuristic fallback runs without it)
OPENAI_API_KEY=

# Admin portal shared secret
MIU_ADMIN_KEY=change-me-to-a-long-random-string

# Optional: comma-separated dev origins for Next.js
# ALLOWED_DEV_ORIGINS=127.0.0.1,192.168.1.10
